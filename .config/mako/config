# GLOBAL
max-history=5
sort=-time

# BINDING OPTIONS
on-button-left=invoke-default-action
on-button-middle=dismiss-all
on-button-right=dismiss-all
on-touch=dismiss

# STYLE OPTIONS
font=Noto Sans 14
width=300
height=100
margin=4
padding=15
border-size=2
border-radius=10
icons=1
max-icon-size=48
icon-location=left
markup=1
actions=1
history=1
text-alignment=center
default-timeout=5000
ignore-timeout=0
max-visible=5
layer=overlay
anchor=top-right

background-color=#222436
text-color=#c8d3f5
border-color=#2f334d
progress-color=over #82aaff

[urgency=low]
border-color=#82aaff
default-timeout=2000

[urgency=normal]
border-color=#82aaff
default-timeout=5000

[urgency=high]
border-color=#ff757f
text-color=#ff757f
default-timeout=0

[category=mpd]
border-color=#ffc777
default-timeout=2000
group-by=category
