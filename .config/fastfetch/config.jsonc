{
    "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
    "logo": {
        "type": "builtin",
        "source": "arch"
    },
    "modules": [
        "title",
        "separator",
        {
            "type": "os",
            "format": "Arch Linux ({12})",
            "keyColor": "red"
        }, 
        {
            "type": "kernel",
            "keyColor": "green"
        },
        {
            "type": "uptime",
            "keyColor": "yellow"
        },
        {
            "type": "packages",
            "format": "{} (pacman)",
            "keyColor": "blue"
        },
        {
            "type": "shell",
            "keyColor": "magenta"
        },
        {
            "type": "wm",
            "keyColor": "cyan"
        },
        {
            "type": "theme",
            "keyColor": "white"
        },
        {
            "type": "icons",
            "keyColor": "red"
        },
        {
            "type": "font",
            "keyColor": "green"
        },
        {
            "type": "cursor",
            "keyColor": "yellow"
        },
        {
            "type": "terminal",
            "keyColor": "blue"
        },
        {
            "type": "terminalfont",
            "keyColor": "magenta"
        },
        {
            "type": "cpu",
            "keyColor": "cyan"
        },
        {
            "type": "gpu",
            "keyColor": "white"
        },
        {
            "type": "memory",
            "keyColor": "red"
        },
        {
            "type": "display",
            "keyColor": "green"
        },
    ]
}
